extends ../layout

block content

  include ../includes/backToTaskList
  include ../includes/personalDetailsSummary

  h2.heading-large Reporting instructions
  p Enter the details of where the offender should report


  form#reportingForm(method='post')
    input(type="hidden" name="_csrf" value=csrfToken)
    input(type="hidden" name="bookingId" value=bookingId)

    div#address.pure-g
      div.pure-u-1.pure-u-md-2-5
        div.pure-g.largeMarginBottom.midPaddingBottom
          div.pure-u-1.pure-u-md-4-5
            div(class=errorObject.name ? "form-group form-group-error": "form-group")
              label.form-label(for="name") Name (or Duty Officer if unknown)
              if errorObject.name
                span.error-message #{errorObject.name}
              input#name.form-control(class=errorObject.name ? "form-control-error form-control midMarginBottom": "midMarginBottom form-control" name="name" type="text" value=data.name aria-label="Name (or Duty Officer's name)")

            div(class=errorObject.organisation ? "form-group form-group-error": "form-group")
              label.form-label(for="organisation") CRC/NPS organisation
              if errorObject.organisation
                span.error-message #{errorObject.organisation}
              input#organisation.form-control(class=errorObject.organisation ? "form-control-error form-control": "form-control" name="organisation" type="text" value=data.organisation aria-label="CRC or NPS organisation name")

            div(class=errorObject.buildingAndStreet1 ? "form-group form-group-error": "form-group")
              label.form-label(for="building") Building and street
              if errorObject.buildingAndStreet1
                span.error-message #{errorObject.buildingAndStreet1} 
              input#building.midMarginBottom.form-control(class=errorObject.buildingAndStreet1 ? "form-control-error form-control": "form-control" name="buildingAndStreet1" type="text" value=data.buildingAndStreet1 aria-label="Building and street")
              input#street.form-control.block(name="buildingAndStreet2" type="text" value=data.buildingAndStreet2)

            div(class=errorObject.townOrCity ? "form-group form-group-error": "form-group")
              label.form-label(for="town") Town or city 
              if errorObject.townOrCity
                span.error-message #{errorObject.townOrCity}
              input#town.form-control(class=errorObject.townOrCity ? "form-control-error form-control": "form-control" name="townOrCity" type="text" value=data.townOrCity aria-label="Town or city")

            div.pure-g
              div.pure-u-1.pure-u-md-3-5
                div(class=errorObject.postcode ? "form-group form-group-error": "form-group")
                  label.form-label(for="postcode") Postcode
                  if errorObject.postcode
                    span.error-message #{errorObject.postcode}
                  input#postcode.form-control.small(class=errorObject.postcode ? "form-control-error form-control": "form-control" name="postcode" type="text" value=data.postcode aria-label="Postcode")
            div.pure-g
              div.pure-u-1.pure-u-md-3-5
                div(class=errorObject.telephone ? "form-group form-group-error": "form-group")
                  label.form-label(for="telephone") Telephone
                  if errorObject.telephone
                    span.error-message #{errorObject.telephone}
                  input#telephone.form-control.small(class=errorObject.telephone ? "form-control-error form-control": "form-control" name="telephone" type="text" value=data.telephone aria-label="Telephone")

            p Enter the reporting date and time

            div(class=errorObject.reportingDate ? "form-group form-group-error": "form-group")
              fieldset
                if errorObject.reportingDate
                  legend
                    span.error-message #{errorObject.reportingDate}
                div.form-date
                  div.form-group.form-group-day
                    label.form-label(for="reportingDate") Day
                    input#reportingDate(class=errorObject.reportingDate ? "form-control-error form-control": "form-control" name="reportingDay" type="number" pattern="[0-9]*" value=data.reportingDay)

                  div.form-group.form-group-month
                    label.form-label(for="reportingMonth") Month
                    input#reportingMonth(class=errorObject.reportingDate ? "form-control-error form-control": "form-control" name="reportingMonth" type="number" pattern="[0-9]*" value=data.reportingMonth)

                  div.form-group.form-group-year
                    label.form-label(for="reportingYear") Year
                    input#reportingYear(class=errorObject.reportingDate ? "form-control-error form-control": "form-control" name="reportingYear" type="number" pattern="[0-9]*" value=data.reportingYear)

            div(class=errorObject.reportingTime ? "form-group form-group-error": "form-group")
              label.form-label(for="reportingTime")
                span Time
                if errorObject.reportingTime
                  span.error-message #{errorObject.reportingTime}
              input#reportingTime(class=errorObject.reportingTime ? "form-control-error form-control midMarginBottom": "midMarginBottom form-control" name="reportingTime" type="time" value=data.reportingTime)

    if (action === 'change')
      include ../includes/formSubmit
    else
      include ../includes/saveAndReturn

