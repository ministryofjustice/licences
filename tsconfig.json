{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compileOnSave": true,
  "isolatedModules": true,
  "compilerOptions": {
    "outDir": "./dist",
    "sourceMap": true,
    "skipLibCheck": true,
    "noEmit": false,
    "allowJs": true,
    "checkJs": true,
    "resolveJsonModule": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "exclude": ["node_modules", "assets/**/*.js", "dist", "licences-specs", "build"],
  "include": ["**/*.js", "**/*.ts"]
}
